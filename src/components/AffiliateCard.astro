---
export interface Props {
  title: string;
  price: string;
  rating: string;
  pros: string[];
  cons: string[];
  jdLink?: string;
  tmallLink?: string;
}

const { title, price, rating, pros, cons, jdLink, tmallLink } = Astro.props;
---

<div class="bg-white rounded-xl border-2 border-blue-100 p-6 my-6 shadow-sm">
  <div class="flex items-start justify-between mb-4">
    <div>
      <h3 class="text-xl font-bold text-gray-900 mb-1">{title}</h3>
      <p class="text-lg text-red-600 font-semibold">参考价：{price}</p>
    </div>
    <div class="text-center bg-yellow-50 px-4 py-2 rounded-lg">
      <span class="block text-xs text-gray-500">评分</span>
      <span class="block text-xl font-bold text-yellow-600">{rating}</span>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div>
      <p class="text-sm font-semibold text-green-700 mb-2">✅ 优点</p>
      <ul class="text-sm text-gray-600 space-y-1">
        {pros.map(p => <li>{p}</li>)}
      </ul>
    </div>
    <div>
      <p class="text-sm font-semibold text-red-700 mb-2">⚠️ 缺点</p>
      <ul class="text-sm text-gray-600 space-y-1">
        {cons.map(c => <li>{c}</li>)}
      </ul>
    </div>
  </div>

  <div class="flex flex-wrap gap-3 mt-4 pt-4 border-t border-gray-100">
    {jdLink && (
      <a
        href={jdLink}
        target="_blank"
        rel="nofollow sponsored"
        class="inline-flex items-center gap-2 bg-red-600 text-white px-6 py-2.5 rounded-lg hover:bg-red-700 transition-colors text-sm font-medium"
      >
        京东购买 →
      </a>
    )}
    {tmallLink && (
      <a
        href={tmallLink}
        target="_blank"
        rel="nofollow sponsored"
        class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium"
      >
        天猫购买 →
      </a>
    )}
  </div>
</div>
