---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, pubDate, category } = article.data;
---

<article class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-4 mb-3">
    <span class="inline-block text-xs font-medium text-blue-600 bg-blue-50 px-3 py-1 rounded-full">
      {category}
    </span>
    <time class="text-xs text-gray-400 shrink-0">
      {pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </div>
  <h3 class="text-lg font-semibold mb-2">
    <a href={`/blog/${article.id}`} class="text-gray-900 hover:text-blue-600 no-underline">
      {title}
    </a>
  </h3>
  <p class="text-sm text-gray-500 mb-4 line-clamp-2">{description}</p>
  <a
    href={`/blog/${article.id}`}
    class="text-sm text-blue-600 hover:text-blue-800 font-medium"
  >
    阅读全文 →
  </a>
</article>
