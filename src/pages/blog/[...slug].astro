---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { title, description, pubDate, category, tags } = article.data;
const { Content } = await render(article);
---

<Layout title={title} description={description}>
  <!-- 面包屑 -->
  <nav class="text-sm text-gray-400 mb-6">
    <a href="/" class="hover:text-blue-600">首页</a>
    <span class="mx-2">/</span>
    <a href={`/categories/${encodeURIComponent(category)}`} class="hover:text-blue-600">{category}</a>
    <span class="mx-2">/</span>
    <span class="text-gray-600">{title}</span>
  </nav>

  <article class="bg-white rounded-xl border border-gray-200 p-6 md:p-8">
    <!-- 文章头部 -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="text-xs font-medium text-blue-600 bg-blue-50 px-3 py-1 rounded-full">
          {category}
        </span>
        <time class="text-xs text-gray-400">
          {pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{title}</h1>
      <p class="text-gray-500 text-lg">{description}</p>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <span class="text-xs text-gray-400 bg-gray-50 px-2 py-1 rounded">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- 文章正文 -->
    <div class="prose prose-gray max-w-none">
      <Content />
    </div>

    <!-- 底部声明 -->
    <div class="mt-8 pt-6 border-t border-gray-100">
      <p class="text-xs text-gray-400 leading-relaxed">
        📢 声明：本站部分链接为京东/淘宝联盟推广链接，如您通过点击链接购买产品，我们可能会获得佣金。
        这不会影响您的购买价格，但能帮助我们持续提供优质内容。所有评测均基于真实体验，坚持客观公正。
      </p>
    </div>
  </article>

  <!-- 导航 -->
  <div class="flex justify-between mt-8">
    <a href="/blog" class="text-sm text-blue-600 hover:text-blue-800">← 返回文章列表</a>
    <a href="/" class="text-sm text-blue-600 hover:text-blue-800">返回首页 →</a>
  </div>
</Layout>
