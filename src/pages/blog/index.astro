---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = articles.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// 获取所有分类
const categories = [...new Set(articles.map(a => a.data.category))];
---

<Layout title="全部文章" description="浏览所有耳机评测文章">
  <h1>📚 全部评测文章</h1>

  <!-- 分类筛选 -->
  <div class="flex flex-wrap gap-2 mb-8">
    <a
      href="/blog"
      class="inline-block text-sm px-4 py-2 rounded-full bg-blue-600 text-white"
    >
      全部
    </a>
    {categories.map(cat => (
      <a
        href={`/categories/${encodeURIComponent(cat)}`}
        class="inline-block text-sm px-4 py-2 rounded-full bg-gray-100 text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition-colors"
      >
        {cat}
      </a>
    ))}
  </div>

  {sortedArticles.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedArticles.map(article => <ArticleCard article={article} />)}
    </div>
  ) : (
    <div class="text-center py-16 text-gray-400">
      <p class="text-5xl mb-4">📝</p>
      <p class="text-lg">还没有文章，敬请期待！</p>
    </div>
  )}
</Layout>
